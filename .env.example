# ─── Database ────────────────────────────────────────────────────────────────────
# Local:  postgresql://postgres:password@localhost:5432/codeethnics?schema=public
# AWS RDS (ap-south-1):
DATABASE_URL="postgresql://postgres:password@localhost:5432/codeethnics?schema=public"

# ─── Better Auth ─────────────────────────────────────────────────────────────────
# BETTER_AUTH_SECRET: random 32+ char string (openssl rand -base64 32)
# BETTER_AUTH_URL: your deployed backend URL (no trailing slash)
BETTER_AUTH_SECRET="your-random-secret"
BETTER_AUTH_URL="http://localhost:5000"

# ─── Server ──────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Email (Mailtrap for dev, AWS SES for prod) ──────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=

# ─── CORS / Frontend ─────────────────────────────────────────────────────────────
# Comma-separated origins: CORS_ORIGINS=https://app.codeethnics.com,https://www.codeethnics.com
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=
